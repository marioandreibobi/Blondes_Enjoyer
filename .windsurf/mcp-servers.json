{
  "mcp-playwright": {
    "command": "npx",
    "args": ["-y", "@playwright/mcp"]
  },
  "memory": {
    "command": "npx",
    "args": ["-y", "@modelcontextprotocol/server-memory"]
  },
  "context7": {
    "command": "npx",
    "args": ["-y", "@upstash/context7-mcp", "--api-key", "YOUR_CONTEXT7_API_KEY_HERE"]
  },
  "sentry": {
    "url": "https://mcp.sentry.dev/mcp"
  }
}
