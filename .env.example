# Database — PostgreSQL connection string (port 5435 matches docker-compose.yml)
DATABASE_URL="postgresql://codeatlas:codeatlas@localhost:5435/codeatlas?schema=public"

# GitHub — Personal Access Token with repo read access
GITHUB_TOKEN="ghp_your_token_here"

# AI — Uses GitHub Models via Copilot Pro (GITHUB_TOKEN is the API key)

# Stripe — Payment processing
STRIPE_SECRET_KEY="sk_test_your_stripe_secret_key_here"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_your_stripe_publishable_key_here"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Google Maps — Required for the City Map view
# Get a key at https://console.cloud.google.com/ (enable Maps JavaScript API)
# Map ID is needed for AdvancedMarker elements (create one in Cloud Console → Map Management)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="your_google_maps_api_key_here"
NEXT_PUBLIC_GOOGLE_MAPS_ID="your_google_maps_id_here"

# SMTP — Email for verification codes (Gmail example)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your_email@gmail.com"
SMTP_PASS="your_app_password"
SMTP_FROM="CodeAtlas <your_email@gmail.com>"
