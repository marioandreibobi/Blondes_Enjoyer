# Database — PostgreSQL connection string
DATABASE_URL="postgresql://codeatlas:codeatlas@localhost:5432/codeatlas?schema=public"

# GitHub — Personal Access Token with repo read access
GITHUB_TOKEN="ghp_your_token_here"

# Featherless AI — OpenAI-compatible API
FEATHERLESS_API_KEY="your_featherless_api_key_here"

# Stripe — Payment processing
STRIPE_SECRET_KEY="sk_test_your_stripe_secret_key_here"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_your_stripe_publishable_key_here"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# SMTP — Email for verification codes (Gmail example)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your_email@gmail.com"
SMTP_PASS="your_app_password"
SMTP_FROM="CodeAtlas <your_email@gmail.com>"
